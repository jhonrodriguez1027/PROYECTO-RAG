# Configuración del Asistente RAG - RETIE

# =========================================================
# API Keys - REQUERIDO PARA FUNCIONAMIENTO
# =========================================================
# Tu clave de API de Google Generative AI
# Obtener en: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=tu_api_key_aqui

# =========================================================
# Configuración de la Aplicación Flask
# =========================================================
# Puerto de la aplicación (default: 5000)
FLASK_PORT=5000

# Modo de desarrollo (True para desarrollo, False para producción)
FLASK_DEBUG=True

# =========================================================
# Configuración del Modelo de Lenguaje
# =========================================================
# Modelo a utilizar
LLM_MODEL=gemini-2.5-flash

# Temperatura de las respuestas (0.0 = determinístico, 1.0 = creativo)
LLM_TEMPERATURE=0.2

# =========================================================
# Configuración de Embeddings
# =========================================================
# Usar embeddings locales (True) o Google Gemini (False)
USE_LOCAL_EMBEDDINGS=True

# Modelo local de embeddings
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =========================================================
# Configuración del Vector Store
# =========================================================
# Directorio donde se almacena ChromaDB
PERSIST_DIRECTORY=./chromadb

# =========================================================
# Parámetros de Recuperación
# =========================================================
# Número de documentos a recuperar por consulta
TOP_K=10

# Tamaño de chunk para procesamiento de documentos
CHUNK_SIZE=1500

# Overlap entre chunks
CHUNK_OVERLAP=300
# Flask Web Framework
Flask==3.0.0
Flask-CORS==4.0.0
Werkzeug==3.0.1

# LangChain y LLM
langchain==0.1.17
langchain-community==0.1.22
langchain-google-genai==0.0.13
langchain-text-splitters==0.0.1
langchain-chroma==0.1.2

# Modelos y Embeddings
google-generativeai==0.3.3
sentence-transformers==2.3.1

# Vector DB
chromadb==0.4.24

# Utilidades
python-dotenv==1.0.0
pydantic==2.5.3
requests==2.31.0

# Modelos de lenguaje
huggingface-hub==0.19.4
